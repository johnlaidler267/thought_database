# Frontend environment variables (Vite)
# Copy this file to .env and fill in your values: cp .env.example .env
# Only variables prefixed with VITE_ are exposed to the client.

# Supabase (required for auth and data)
# From Supabase Dashboard -> Settings -> API: Project URL and anon/public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API URL (required for transcribe, clean, tags, etc.)
# Use local backend in development; use your deployed backend URL in production
VITE_API_URL=http://localhost:3001
