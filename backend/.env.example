# Backend environment variables
# Copy this file to .env and fill in your values: cp .env.example .env

# Server
PORT=3001

# CORS / Frontend URL (required in production)
# Set to your frontend origin, e.g. https://your-app.vercel.app
# FRONTEND_URL=
# CORS_ORIGIN=

# Supabase (required for API auth and data)
# From Supabase Dashboard -> Settings -> API: Project URL and service_role key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Groq (transcription, tagging, reflect, distill, thought starters)
# Get key at https://console.groq.com
GROQ_API_KEY=

# Google AI Studio (text cleaning / Gemini)
# Get key at https://aistudio.google.com
GOOGLE_AI_API_KEY=

# Stripe (optional). See docs/STRIPE_INTEGRATION_GUIDE.md
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Rate limiting (optional, default 100 per 15 min per IP)
# RATE_LIMIT_MAX=100
